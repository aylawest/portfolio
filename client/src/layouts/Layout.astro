---
import '../styles/global.css';
import '../styles/fonts.css';
import '../styles/colors.css';
import '../styles/mode.css';
import Navbar from '../components/global/navigation/Navbar.astro';
import Footer from '../components/global/navigation/Footer.astro';
import Contact from '../components/pagesections/index/Contact.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.15.1/devicon.min.css">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Navbar />
		<main>
			<slot />
		</main>
		<Contact />
		<Footer />
	</body>
</html>

<!-- font awesome icons -->
<script src="https://kit.fontawesome.com/67b26fcce6.js" crossorigin="anonymous"></script>

<!-- iconify icons -->
<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
