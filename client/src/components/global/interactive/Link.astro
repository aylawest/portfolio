---
interface Props {
	href: string;
  id?: string;
  style: string;
  aria: string;
  icon?: string;
  text: string;
}

const { href, id, style, aria, icon, text } = Astro.props;
---

<a 
  href={ href } 
  id={ id } 
  class={ style } 
  aria-label={ aria }>
  <i class={ icon }></i> { text }
</a>

<style>
  a {
    display: inline-block;
  }

  .plain {
  }

  .plain:hover {
    color: var(--theme-accent-2)
  }

  .primary {
    background-color: var(--theme-body);
    border: 1px solid var(--theme-body);
    padding: 8px 14px;
    border-radius: 4px;
    color: var(--theme-background);
  }

  .primary:hover {
    background-color: var(--theme-accent-2);
    border: 1px solid var(--theme-accent-2);
    color: var(--theme-background);
  }

  .primary i {
    color: var(--theme-title);
  }

  .primary:hover i {
    color: var(--theme-background);
  }

  .secondary {
    padding: 8px 14px;
    border-radius: 4px;
    border: 1px solid var(--theme-accent-2);
    color: var(--theme-accent-2);
  }

  .secondary:hover {
    color: var(--theme-background);
    background-color: var(--theme-accent-2);
    border: 1px solid var(--theme-accent-2);
  }

  .secondary i {
    color: var(--theme-title);
  }

  .secondary:hover i {
    color: var(--theme-background);
  }
</style>