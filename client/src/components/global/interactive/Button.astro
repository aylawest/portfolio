---
interface Props {
	id?: string;
  style: string;
  aria: string;
  icon?: string;
  text: string;
}

const { id, style, aria, icon, text } = Astro.props;
---

<button id={ id } class={ style } aria-label={ aria } >
  <i class={ icon }></i> { text }
</button>

<style>
  a {
    display: inline-block;
  }

  .plain {
  }

  .plain:hover {
    color: rgb(59, 190, 78);
  }

  .primary {
    background-color: rgb(27, 26, 26);
    padding: 8px 14px;
    border-radius: 4px;
    border: 1px solid rgb(27, 26, 26);
    color: white;
  }

  .primary:hover {
    background-color: white;
    border: 1px solid rgb(27, 26, 26);
    color: rgb(27, 26, 26);
  }

  .primary i {
    color: white;
  }

  .primary:hover i {
    color: rgb(27, 26, 26);
  }

  .secondary {
    padding: 8px 14px;
    border-radius: 4px;
    border: 1px solid rgb(27, 26, 26);
  }

  .secondary:hover {
    color: white;
    background-color: rgb(27, 26, 26);
    border: 1px solid rgb(27, 26, 26);
  }

  .secondary i {
    color: rgb(27, 26, 26);
  }

  .secondary:hover i {
    color: white;
  }
</style>