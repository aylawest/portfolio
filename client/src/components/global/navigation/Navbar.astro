---
import Logo from "../flair/Logo.astro";
import Link from "../interactive/Link.astro";
---

<header id="navbar">
  <container>
    <Logo />
    <nav aria-label="navigation">
      <ul>
        <li><Link href="/" style="plain" text="About" /></li>
        <li><Link href="/" style="primary" text="Projects" /></li>
        <li><Link href="/" style="secondary" text="Contact" /></li>
      </ul>
    </nav>
  </container>
</header>

<style>
  #navbar {
    
  }

  #navbar container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  ul {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  li {
    list-style-type: none;
  }
</style>