---
import Logo from "../flair/Logo.astro";
import Link from "../interactive/Link.astro";
import ToggleMode from "../interactive/ToggleMode.astro";
---

<header id="navbar" class="no-print">
  <div class="container">
    <Logo />
    <nav aria-label="navigation">
      <ul>
        <li><ToggleMode /></li>
        <li class="nav-links"><Link href="/#about" style="plain" aria="About" text="About" /></li>
        <li class="nav-links"><Link href="/#projects" style="plain" aria="Projects" text="Projects" /></li>
        <li class="nav-links"><Link href="/#work-with-me" style="plain" aria="Work with me" text="Work with me" /></li>
        <li class="nav-links"><Link href="/resume" style="plain" aria="Resume" text="Resume" /></li>
        <li><Link href="#contact" style="primary" aria= "Contact" text="Contact" /></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  #navbar {
    
  }

  #navbar .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  ul {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  li {
    list-style-type: none;
  }

  @media screen and (max-width: 800px) {
    .nav-links {
      display: none;
    }
  }
</style>