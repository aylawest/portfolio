---
import Link from '../../global/interactive/Link.astro';
---

<section id="hero">
  <container>
    <p>Lorem</p>
    <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Cum, explicabo.</p>
    <div class="link-container">
      <Link href="#projects" style="primary" icon="fa-solid fa-folder-open" aria="Work" text="Work" />
      <Link href="/" style="secondary" icon="fa-solid fa-file" aria="Resume" text="Resume" />
    </div>
    <a href="#about"><i class="fa-solid fa-arrow-down"></i></a>
  </container>
</section>

<style>
  #hero {
    height: calc(100vh - 99px);
    min-height: 300px;
  }

  #hero container {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    gap: 20px;
    align-items: flex-start;
  }

  i {
    font-size: 90px;
    opacity: .05;
  }

  i:hover {
    transform: translateY(2px);
    transition: .1s;
    opacity: .1;
  }

  .arrow-container {
      position: relative;
      width: 30px;
      height: 150px; /* Adjust the height as needed */
    }

    .arrow {
      position: absolute;
      left: 50%;
      top: 0;
      transform: translateX(-50%);
      width: 0;
      height: 0;
      border-style: solid;
      border-width: 0 15px 60px 15px; /* Adjust the width and height of the arrowhead */
      border-color: transparent transparent #007bff transparent; /* Adjust the color as needed */
    }

    .tail {
      position: absolute;
      left: 50%;
      top: 60px; /* Adjust the distance from the top as needed */
      transform: translateX(-50%);
      width: 4px; /* Adjust the width of the tail */
      height: 90px; /* Adjust the height of the tail */
      background-color: #007bff; /* Adjust the color as needed */
      border-radius: 2px; /* Optional: Add rounded corners to the tail */
    }

    .tail:before, .tail:after {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      background-color: inherit;
    }

    .tail:before {
      transform: skewX(-30deg);
      transform-origin: bottom;
    }

    .tail:after {
      transform: skewX(30deg);
      transform-origin: top;
    }
</style>