---
import ProjectCard from "../../global/cards/ProjectCard.astro";
import Title from "../../global/titles/Title.astro";
---

<section id="projects">
  <container>
    <Title text="Selected Work" subtext="Fueled by passion and developed with precision." />
    <div class="btn-container">
      <button id="all" class="active">All</button>
      <button id="back-end"></button>
      <button id="full-stack" class="active"></button>
      <button id="front-end"></button>
    </div>
  
    <div id="projects-container">
      <div class="full-stack project-card" id="project-1">
        <ProjectCard 
          img="https://www.shutterstock.com/blog/wp-content/uploads/sites/5/2020/02/Usign-Gradients-Featured-Image.jpg" 
          title="Full-stack Project" 
          description="Description."
          href=""
          src=""
          tech={['JavaScript', 'React', 'HTML5', 'CSS3', 'SCSS']} 
        />
      </div>
      <div class="back-end project-card" id="project-2">
        <ProjectCard 
          img="https://www.shutterstock.com/blog/wp-content/uploads/sites/5/2020/02/Usign-Gradients-Featured-Image.jpg" 
          title="Back-end Project" 
          description="Description."
          href=""
          src=""
          tech={['Python']} 
        />
      </div>
      <div class="back-end project-card" id="project-3">
        <ProjectCard 
          img="https://www.shutterstock.com/blog/wp-content/uploads/sites/5/2020/02/Usign-Gradients-Featured-Image.jpg" 
          title="Back-end Project" 
          description="Description."
          href=""
          src=""
          tech={['Java', 'SQL', 'MySQL']} 
        />
      </div>
      <div class="front-end project-card" id="project-4">
        <ProjectCard 
          img="https://www.shutterstock.com/blog/wp-content/uploads/sites/5/2020/02/Usign-Gradients-Featured-Image.jpg" 
          title="Front-end Project" 
          description="Description."
          href=""
          src=""
          tech={['JavaScript', 'Astro', 'HTML', 'CSS']} 
        />
      </div>
    </div>
  </container>
</section>

<style>
  #projects {

  }
  
  #projects container {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-start;
  }

  .btn-container {
    display: flex;
    margin-bottom: 30px;
    gap: 10px;
    background-color: var(--theme-background-shade);
    padding: 14px;
    border-radius: 10px;
  }

  button {
    font-size: 17px;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    border: 0;
    border-radius: 50%;
    background-color: var(--theme-background-shade);
    font-family: var(--font-body);
    -webkit-box-shadow: 0px 3px 0px 0px rgba(0,0,0,0.75);
    -moz-box-shadow: 0px 3px 0px 0px rgba(0,0,0,0.75);
    box-shadow: 0px 3px 0px 0px rgba(0,0,0,0.75);
  }

  button:hover {
    transition: .1s;
    cursor: pointer;
    background-color: var(--theme-accent-2);
    transform: translateY(2px);
    -webkit-box-shadow: 0px 0px 0px 0px rgba(0,0,0,0.75);
    -moz-box-shadow: 0px 0px 0px 0px rgba(0,0,0,0.75);
    box-shadow: 0px 0px 0px 0px rgba(0,0,0,0.75); 
  }

  #front-end {
    background-image: linear-gradient(90deg, rgb(255, 255, 255) 50%, rgb(34, 33, 33) 50%);
  }
  #back-end {
    background-image: linear-gradient(90deg, rgb(34, 33, 33) 50%, rgb(255, 255, 255) 50%);
  }
  #full-stack {
    background-color: rgb(34, 33, 33);
  }

  #projects-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: ;
    grid-column-gap: 30px;
    grid-row-gap: 30px;
  }

  .active {
    background-color: var(--theme-accent-2);
    color: var(--theme-background);
  }

  @media screen and (max-width: 800px) {
    #projects-container {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const filterBtns = document.querySelectorAll(".btn-container button");
    const projects = document.querySelectorAll(".project-card");

    function filterProjects(category, button) {
      projects.forEach(project => {
        const projectElement = project as HTMLElement;
        if (category === "all" || project.classList.contains(category)) {
          projectElement.style.display = "block";
        } else {
          projectElement.style.display = "none";
        }
      });

      filterBtns.forEach(btn => btn.classList.remove("active"));
      button.classList.add("active");
    }

    filterBtns.forEach(button => {
      button.addEventListener("click", function () {
        const category = button.id;
        filterProjects(category, button as HTMLButtonElement);
      });
    });

    filterProjects("all", document.getElementById("all") as HTMLButtonElement);
  });

</script>